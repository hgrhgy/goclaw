# Backend connection settings
# ============================
# Option 1: Use relative paths (works with Vite proxy in dev, or nginx in prod)
# - Leave both VITE_API_URL and VITE_WS_URL empty or commented
#
# Option 2: Use absolute URLs (connect directly to backend)
# - Set VITE_API_URL to your backend HTTP address
# - VITE_WS_URL will be automatically derived from VITE_API_URL
#   (or you can set it explicitly if needed)

# Example for local development:
# VITE_API_URL=http://localhost:18790
# VITE_WS_URL=ws://localhost:18790/ws

# Example for remote server:
# VITE_API_URL=http://192.168.1.100:18790
# VITE_WS_URL=ws://192.168.1.100:18790/ws

# WebSocket URL - can be absolute (ws://host:port/path) or relative (/ws)
# If VITE_API_URL is set, this will be auto-derived unless explicitly specified
VITE_WS_URL=

# Backend API URL - full URL including protocol, IP and port
# When set, HTTP requests will go directly to this URL instead of using relative paths
# Leave empty to use relative paths (works with proxy in dev, or nginx in prod)
VITE_API_URL=
